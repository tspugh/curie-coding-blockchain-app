# Copy to .env and fill in. Never commit .env.

# --- Wallet mode (R11) -------------------------------------------------------
# "simulated" (default): no chain, no funds, agent ruling mocked — the dev/CI
# loop and the web app run fully without a wallet. "real": ethers signer vs the
# deployed contract on Somnia (requires PRIVATE_KEY + a deployed address below).
SOMNIA_WALLET_MODE=simulated

# Which Somnia network to target: "testnet" (Shannon) or "mainnet".
SOMNIA_NETWORK=testnet

# Wallet private key for signing transactions (real mode only).
# Use a dedicated dev wallet — never a key that holds real funds.
# Leave blank for simulated mode / read-only (view-call) usage.
PRIVATE_KEY=

# Optional: override the RPC endpoint. Leave blank to use the network default
# (see src/config/networks.ts) / the somnia-agent-kit bundled default.
SOMNIA_RPC_URL=

# --- Deployed contract (real mode) -------------------------------------------
# Address printed by `npm --prefix contracts run deploy` (scripts/deploy.ts).
# RealBackend (src/contract/real.ts) reads this to reach the live contract.
# RECORD THE DEPLOYED TESTNET ADDRESS HERE after deploying (SPEC-0001 §4).
COVERAGE_CONTRACT_ADDRESS=

# --- Deploy-time constructor args (used by contracts/scripts/deploy.ts) ------
# Somnia agent-platform (IAgentRequester) address the contract fires requests at.
AGENT_PLATFORM_ADDRESS=
# Registered agent id used to resolve disputes (LLM Parse Website / JSON API).
AGENT_ID=0
# Optional extra per-agent reward added on top of getRequestDeposit() (R9).
# Set on-chain via setAgentReward(); not read at deploy time.
AGENT_REWARD=0
