{
  "name": "curie-claims-protocol",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Curie Claims Protocol — agentic medical-claims negotiation and settlement on the Somnia blockchain.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview --port 4173",
    "test": "npm run check-ruling-abi && npm run typecheck && npm run test:lib && npm --prefix contracts test",
    "test:lib": "node --import tsx --test \"src/**/*.test.ts\" \"web/src/**/*.test.ts\"",
    "test:e2e": "bash web/tests/agent-browser/run.sh",
    "test:real-local": "bash scripts/real-backend-localnode.sh",
    "demo:orchestrator": "node scripts/orchestrator-demo.mjs",
    "check-ruling-abi": "tsx scripts/check-ruling-abi.ts",
    "verify-deploy": "tsx scripts/verify-deploy.ts",
    "keeper": "tsx scripts/keeper.ts",
    "keeper:once": "tsx scripts/keeper.ts --once"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "somnia-agent-kit": "^3.0.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.11"
  }
}
